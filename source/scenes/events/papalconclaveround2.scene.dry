{!<tr><td><div class="box" style='background-color:#6767E2'> </div> !} Europe: {!</td><td>!} [+ europe_p +] {!</td><td>!} [+ str_change_europe +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#803D2C'> </div> !} North America: {!</td><td>!} [+ namerica_p +] {!</td><td>!} [+ str_change_namerica +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#D49382'> </div> !} South America: {!</td><td>!} [+ samerica_p +] {!</td><td>!} [+ str_change_samerica +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#F7CC0C'> </div> !} Asia: {!</td><td>!} [+ asia_p +] {!</td><td>!} [+ str_change_asia +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#E7C20C'> </div> !} Oceania: {!</td><td>!} [+ oceania_p +] {!</td><td>!} [+ str_change_oceania +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#434343'> </div> !} Africa: {!</td><td>!} [+ africa_p +] {!</td><td>!} [+ str_change_africa +] {!</td></tr>!}

{!</table>!}

